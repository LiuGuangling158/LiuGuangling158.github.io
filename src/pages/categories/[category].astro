---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { categories, getCategory } from '../../config/categories';
import { site } from '../../config/site';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return categories.map((cat) => ({
    params: { category: cat.slug },
  }));
};

const { category } = Astro.params;

const cat = getCategory(category!);
if (!cat) {
  return Astro.redirect('/categories/');
}

const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === category
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={`${cat.name} — 文章分类 — ${site.name}`}
  description={cat.description}
>
  <header class="mb-8">
    <a
      href="/categories/"
      class="mb-2 inline-block text-sm text-sakura-600 hover:underline"
    >
      ← 全部分类
    </a>
    <h1 class="text-3xl font-bold text-ink">{cat.name}</h1>
    <p class="mt-2 text-ink-muted">
      {cat.description} · 共 {posts.length} 篇文章
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p class="card-kawaii p-6 text-center text-ink-muted">暂无文章</p>
    ) : (
      <ul class="flex flex-col gap-5">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
