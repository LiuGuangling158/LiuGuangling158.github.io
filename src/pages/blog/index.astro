---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import BlogCalendar from '../../components/BlogCalendar.astro';
import { getCollection } from 'astro:content';
import { site } from '../../config/site';
import { getPostDisplayDate } from '../../utils/groupPostsByDate';

const monthParam = Astro.url.searchParams.get('month'); // 仅用于日历初始月份

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 为每篇文章计算展示日期 YYYY-M-D
function postDateKey(post: (typeof posts)[number]): string {
  const d = getPostDisplayDate(post);
  return `${d.getFullYear()}-${d.getMonth() + 1}-${d.getDate()}`;
}
---

<BaseLayout
  title={`博客 — ${site.name}`}
  description="全部文章与标签筛选"
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold text-ink">博客</h1>
    <p class="mt-2 text-ink-muted">
      共 {posts.length} 篇文章
      {' · '}
      <a href="/categories/" class="text-sakura-600 hover:underline">
        按分类浏览
      </a>
    </p>
  </header>

  <!-- 日历 -->
  <div class="mb-6">
    <BlogCalendar posts={allPosts} month={monthParam ?? undefined} mode="blog" />
    <!-- 筛选状态提示（客户端填充） -->
    <p id="cal-filter-hint" class="mt-3 hidden text-sm text-ink-muted"></p>
  </div>

  <ul class="flex flex-col gap-5" id="post-list">
    {posts.map((post) => (
      <li data-post-date={postDateKey(post)}>
        <PostCard post={post} />
      </li>
    ))}
  </ul>
</BaseLayout>
