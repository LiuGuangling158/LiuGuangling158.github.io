---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import BlogCalendar from '../../components/BlogCalendar.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { getCollection } from 'astro:content';
import { site } from '../../config/site';
import { categories } from '../../config/categories';
import { getPostDisplayDate } from '../../utils/groupPostsByDate';

const monthParam = Astro.url.searchParams.get('month'); // 仅用于日历初始月份

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 为每篇文章计算展示日期 YYYY-M-D
function postDateKey(post: (typeof posts)[number]): string {
  const d = getPostDisplayDate(post);
  return `${d.getFullYear()}-${d.getMonth() + 1}-${d.getDate()}`;
}
---

<BaseLayout
  title={`博客 — ${site.name}`}
  description="全部文章与标签筛选"
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold text-ink">博客</h1>
    <p class="mt-2 text-ink-muted">
      共 {posts.length} 篇文章
      {' · '}
      <a href="/categories/" class="text-sakura-600 hover:underline">
        按分类浏览
      </a>
    </p>
  </header>

  <!-- 日历 + 分类筛选 并排 -->
  <div class="filter-row mb-6">
    <div class="filter-col-cal">
      <BlogCalendar posts={allPosts} month={monthParam ?? undefined} mode="blog" />
      <p id="cal-filter-hint" class="mt-2 hidden text-sm text-ink-muted"></p>
    </div>
    <div class="filter-col-cat">
      <CategoryFilter posts={allPosts} categories={categories} mode="blog" />
    </div>
  </div>

  <ul class="flex flex-col gap-4" id="post-list">
    {posts.map((post) => (
      <li data-post-date={postDateKey(post)} data-category={post.data.category || ''}>
        <PostCard post={post} />
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .filter-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
  }

  @media (min-width: 768px) {
    .filter-row {
      grid-template-columns: 320px 1fr;
    }
  }

  @media (min-width: 1024px) {
    .filter-row {
      grid-template-columns: 340px 1fr;
    }
  }

  .filter-col-cal {
    min-width: 0;
  }

  .filter-col-cat {
    min-width: 0;
  }
</style>
