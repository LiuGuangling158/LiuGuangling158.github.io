---
import HomeLayout from '../layouts/HomeLayout.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import DateTimeline from '../components/DateTimeline.astro';
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
---

<HomeLayout>
  <HeroSlideshow slot="hero" />

  <section aria-labelledby="blog-home-title">
    <header class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 id="blog-home-title" class="text-2xl font-bold text-ink">
          博客
        </h2>
        <p class="mt-1 text-sm text-ink-muted">
          按日期查看发布与更新的文章
        </p>
      </div>
      <a href="/blog/" class="btn-kawaii text-sm">全部文章与标签</a>
    </header>

    <DateTimeline posts={allPosts} />
  </section>
</HomeLayout>
