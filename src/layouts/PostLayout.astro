---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { site } from '../config/site';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  headings?: Heading[];
}

const { post, headings = [] } = Astro.props;
const { title, description, pubDate, updatedDate, category } = post.data;
const tocItems = headings.filter((h) => h.depth > 1);
const showSidebar = tocItems.length >= 2;
const pageTitle = `${title} — ${site.name}`;
const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={pageTitle} description={description ?? site.description}>
  <article>
    <header class="card-kawaii mb-8 p-6 sm:p-8">
      <p class="text-sm text-ink-muted">{formattedDate}</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        {title}
      </h1>
      {
        description && (
          <p class="mt-3 text-lg text-ink-muted">{description}</p>
        )
      }
      {
        category && (
          <a
            href={`/categories/${category}/`}
            class="mt-4 inline-block rounded-full bg-sakura-100 px-3 py-1 text-xs font-medium text-sakura-600 hover:bg-sakura-200"
          >
            {category}
          </a>
        )
      }
      {
        updatedDate && (
          <p class="mt-3 text-xs text-ink-muted">
            更新于{' '}
            {updatedDate.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </p>
        )
      }
    </header>

    {/* 正文 + 目录双栏布局（仅在标题数量足够时显示侧边栏） */}
    <div class={showSidebar ? "article-body" : ""}>
      {showSidebar && (
        <aside class="article-sidebar">
          <TableOfContents headings={headings} />
        </aside>
      )}
      <div class={showSidebar ? "article-content card-kawaii prose-blog p-6 sm:p-8" : "card-kawaii prose-blog p-6 sm:p-8"}>
        <slot />
      </div>
    </div>

    <nav
      class="mt-8 flex flex-wrap items-center justify-between gap-4 text-sm"
      aria-label="文章导航"
    >
      <a href="/blog/" class="btn-kawaii">← 返回博客</a>
    </nav>

    <Giscus />
  </article>
</BaseLayout>
