---
import { site } from '../config/site';
import SiteAvatar from './SiteAvatar.astro';

interface Props {
  /** 首页首屏：透明导航浮在背景图上 */
  variant?: 'default' | 'hero';
}

const { variant = 'default' } = Astro.props;
const isHero = variant === 'hero';

const nav = [
  { href: '/', label: '首页' },
  { href: isHero ? '/#blog-main' : '/blog/', label: '博客' },
  { href: '/categories/', label: '分类' },
  { href: '/links/', label: '外链' },
  { href: '/about/', label: '关于' },
];

const current = Astro.url.pathname;
---

<header
  class:list={[
    'top-0 z-50',
    isHero
      ? 'fixed inset-x-0 border-b border-white/20 bg-white/10 backdrop-blur-md'
      : 'sticky border-b border-sakura-200/60 bg-white/75 backdrop-blur-md',
  ]}
>
  <div
    class:list={[
      'mx-auto flex items-center justify-between gap-4 px-4 py-3 sm:px-6',
      isHero ? 'max-w-5xl' : 'max-w-3xl',
    ]}
  >
    <a href="/" class="group flex items-center gap-2">
      <SiteAvatar size="sm" class={isHero ? 'border-white/40' : undefined} />
      <span
        class:list={[
          'font-bold group-hover:text-sakura-600',
          isHero ? 'text-white drop-shadow-sm' : 'text-ink',
        ]}>{site.name}</span
      >
    </a>
    <nav class="flex flex-wrap items-center gap-1 sm:gap-2" aria-label="主导航">
      {
        nav.map(({ href, label }) => {
          const active =
            href === '/'
              ? current === '/'
              : current.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                'rounded-full px-3 py-1.5 text-sm font-medium transition',
                active
                  ? isHero
                    ? 'bg-white/90 text-sakura-600'
                    : 'bg-sakura-200 text-sakura-600'
                  : isHero
                    ? 'text-white/90 hover:bg-white/20 hover:text-white'
                    : 'text-ink-muted hover:bg-sakura-100 hover:text-sakura-600',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
