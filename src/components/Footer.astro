---
import { site } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-sakura-200/60 bg-white/50 py-8">
  <div
    class="mx-auto flex max-w-3xl flex-col items-center gap-3 px-4 text-center text-sm text-ink-muted sm:px-6"
  >
    <p>
      © {year}
      <a
        href={site.github}
        class="font-medium text-sakura-600 hover:underline"
        target="_blank"
        rel="noopener noreferrer">{site.author}'s blog</a
      >
    </p>
    <p class="flex flex-wrap justify-center gap-3">
      <a href="/rss.xml" class="hover:text-sakura-600">RSS</a>
      <span aria-hidden="true">·</span>
      <a
        href={site.github}
        class="hover:text-sakura-600"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
    </p>
  </div>
</footer>
