---
const petals = Array.from({ length: 6 }, (_, i) => ({
  left: `${8 + i * 15}%`,
  delay: `${i * 2.3}s`,
  duration: `${14 + (i % 3) * 4}s`,
  size: 8 + (i % 3) * 2,
}));
---

<div class="pointer-events-none fixed inset-0 overflow-hidden" aria-hidden="true">
  {
    petals.map((p) => (
      <span
        class="sakura-petal"
        style={`left:${p.left};animation-delay:${p.delay};animation-duration:${p.duration};width:${p.size}px;height:${p.size}px;`}
      />
    ))
  }
</div>
