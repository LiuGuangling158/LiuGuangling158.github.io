---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = `/blog/${post.id}/`;
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card-kawaii group p-5 transition hover:-translate-y-0.5 hover:shadow-xl">
  <time class="text-xs text-ink-muted" datetime={pubDate.toISOString()}>
    {dateStr}
  </time>
  <h2 class="mt-2 text-xl font-bold">
    <a
      href={href}
      class="text-ink group-hover:text-sakura-600"
    >
      {title}
    </a>
  </h2>
  {
    description && (
      <p class="mt-2 line-clamp-2 text-sm text-ink-muted">{description}</p>
    )
  }
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {tags.slice(0, 4).map((tag) => (
          <li>
            <span class="rounded-full bg-sakura-50 px-2 py-0.5 text-xs text-sakura-500">
              #{tag}
            </span>
          </li>
        ))}
      </ul>
    )
  }
  <a
    href={href}
    class="mt-4 inline-block text-sm font-medium text-sakura-600 hover:underline"
  >
    阅读全文 →
  </a>
</article>
