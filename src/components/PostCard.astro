---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
const href = `/blog/${post.id}/`;
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card-kawaii group p-5 transition hover:-translate-y-0.5 hover:shadow-xl">
  <time class="inline-flex items-center gap-1.5 text-xs text-ink-muted" datetime={pubDate.toISOString()}>
    <svg class="h-3.5 w-3.5 text-sakura-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="16" y1="2" x2="16" y2="6"></line>
      <line x1="8" y1="2" x2="8" y2="6"></line>
      <line x1="3" y1="10" x2="21" y2="10"></line>
    </svg>
    {dateStr}
  </time>
  <h2 class="mt-2 text-xl font-bold">
    <a
      href={href}
      class="text-ink group-hover:text-sakura-600"
    >
      {title}
    </a>
  </h2>
  {
    description && (
      <p class="mt-2 line-clamp-2 text-sm text-ink-muted">{description}</p>
    )
  }
  {
    category && (
      <a
        href={`/categories/${category}/`}
        class="mt-3 inline-block rounded-full bg-sakura-100 px-3 py-1 text-xs font-medium text-sakura-600 hover:bg-sakura-200 transition"
      >
        {category}
      </a>
    )
  }
  <a
    href={href}
    class="mt-4 inline-block text-sm font-medium text-sakura-600 hover:underline"
  >
    阅读全文 →
  </a>
</article>
