---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, cover } = post.data;
const href = `/blog/${post.id}/`;
const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card card-kawaii group">
  <!-- 左侧装饰线 -->
  <div class="post-card-accent"></div>

  <!-- 内容 -->
  <div class="post-card-body">
    <!-- 顶部：日期 + 分类 -->
    <div class="post-card-meta">
      <time class="post-card-date" datetime={pubDate.toISOString()}>
        <svg class="post-card-date-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        {dateStr}
      </time>
      {
        category && (
          <a href={`/categories/${category}/`} class="post-card-category">
            {category}
          </a>
        )
      }
    </div>

    <!-- 标题 -->
    <h2 class="post-card-title">
      <a href={href} class="post-card-title-link">
        {title}
      </a>
    </h2>

    <!-- 描述 -->
    {
      description && (
        <p class="post-card-desc">{description}</p>
      )
    }

    <!-- 底部：阅读链接 -->
    <a href={href} class="post-card-readmore">
      阅读全文
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>

  <!-- 封面缩略图 -->
  {cover && (
    <a href={href} class="post-card-cover-wrap">
      <img
        src={cover}
        alt={title}
        class="post-card-cover"
        loading="lazy"
      />
    </a>
  )}
</article>

<style>
  .post-card {
    display: flex;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .post-card:hover {
    transform: translateX(4px);
    box-shadow:
      0 2px 8px rgba(240, 98, 146, 0.12),
      0 12px 36px rgba(240, 98, 146, 0.1),
      0 1px 0 rgba(255, 255, 255, 0.9) inset;
  }

  /* 左侧装饰线 */
  .post-card-accent {
    flex-shrink: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--color-sakura-400), var(--color-sakura-300));
    border-radius: 4px 0 0 4px;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .post-card:hover .post-card-accent {
    width: 5px;
    background: linear-gradient(180deg, var(--color-sakura-500), var(--color-sakura-400));
  }

  /* 内容区域 */
  .post-card-body {
    flex: 1;
    min-width: 0;
    padding: 16px 18px;
  }

  /* 元信息行 */
  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .post-card-date {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  .post-card-date-icon {
    width: 14px;
    height: 14px;
    color: var(--color-sakura-400);
    flex-shrink: 0;
  }

  /* 分类 badge */
  .post-card-category {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-sakura-600);
    background: linear-gradient(135deg, var(--color-sakura-100), #ffe4ef);
    border: 1px solid var(--color-sakura-200);
    transition: all 0.2s ease;
  }

  .post-card-category:hover {
    background: linear-gradient(135deg, var(--color-sakura-200), var(--color-sakura-300));
    color: var(--color-sakura-700);
  }

  /* 标题 */
  .post-card-title {
    margin-top: 10px;
    line-height: 1.35;
  }

  .post-card-title-link {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.2s ease;
    background: linear-gradient(var(--color-sakura-500), var(--color-sakura-500)) left bottom / 0% 2px no-repeat;
    padding-bottom: 2px;
  }

  .post-card:hover .post-card-title-link {
    color: var(--color-sakura-600);
    background-size: 100% 2px;
  }

  /* 描述 */
  .post-card-desc {
    margin-top: 8px;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 阅读更多 */
  .post-card-readmore {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sakura-500);
    text-decoration: none;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .post-card-readmore:hover {
    color: var(--color-sakura-600);
    gap: 8px;
  }

  .post-card-readmore svg {
    transition: transform 0.2s ease;
  }

  .post-card-readmore:hover svg {
    transform: translateX(2px);
  }

  /* 封面缩略图 */
  .post-card-cover-wrap {
    flex-shrink: 0;
    width: 140px;
    display: none;
    overflow: hidden;
    border-radius: 0 12px 12px 0;
  }

  @media (min-width: 640px) {
    .post-card-cover-wrap {
      display: block;
    }
  }

  .post-card-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card:hover .post-card-cover {
    transform: scale(1.06);
  }
</style>
