---
import { site } from '../config/site';

// 从 GitHub URL 提取用户名
const githubUsername = site.github.split('/').pop() || site.author;

// 构建时获取 GitHub 用户数据（仅基本信息，不含 star/follower）
interface GitHubUser {
  login: string;
  avatar_url: string;
  html_url: string;
  name: string | null;
  bio: string | null;
}

let user: GitHubUser | null = null;

try {
  const res = await fetch(`https://api.github.com/users/${githubUsername}`);
  if (res.ok) {
    user = await res.json();
  }
} catch {
  // 静默失败，使用降级显示
}

const contributionChartUrl = `https://ghchart.rshah.org/${githubUsername}`;
---

<div class="github-card card-kawaii p-5 sm:p-6">
  {/* 头像 + 基本信息 */}
  <div class="github-profile">
    {user ? (
      <a href={user.html_url} target="_blank" rel="noopener noreferrer">
        <img
          src={user.avatar_url}
          alt={`${user.login} 头像`}
          width="56"
          height="56"
          class="github-avatar"
          loading="lazy"
          decoding="async"
        />
      </a>
    ) : (
      <div class="github-avatar github-avatar-placeholder" />
    )}
    <div class="github-info">
      <a
        href={`https://github.com/${githubUsername}`}
        target="_blank"
        rel="noopener noreferrer"
        class="github-name"
      >
        {user?.name || `@${githubUsername}`}
      </a>
      <span class="github-login">@{githubUsername}</span>
      {user?.bio && <p class="github-bio">{user.bio}</p>}
    </div>
  </div>

  {/* 贡献日历图 */}
  <div class="github-chart-wrap">
    <h3 class="github-chart-title">
      <svg class="github-chart-icon" viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
        <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM2.04 6.33a7.002 7.002 0 0 1 10.18-3.23L8.72 7.73 2.04 6.33ZM1.1 6.85l5.66.89-1.96-3.2a6.97 6.97 0 0 0-3.7 2.31ZM8 14.9a6.9 6.9 0 0 1-5.69-3.06l9.27-3.75L8 14.9Z"/>
      </svg>
      Contributions
    </h3>
    <a
      href={`https://github.com/${githubUsername}`}
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        src={contributionChartUrl}
        alt={`${githubUsername} 的 GitHub 贡献日历`}
        class="github-chart"
        loading="lazy"
        decoding="async"
      />
    </a>
  </div>

  <a
    href={`https://github.com/${githubUsername}`}
    target="_blank"
    rel="noopener noreferrer"
    class="github-follow-btn"
  >
    <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16">
      <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
    </svg>
    Follow on GitHub
  </a>
</div>

<style>
  .github-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .github-profile {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .github-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--color-sakura-200);
    object-fit: cover;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .github-avatar:hover {
    transform: scale(1.08);
  }

  .github-avatar-placeholder {
    background: var(--color-sakura-200);
  }

  .github-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .github-name {
    font-weight: 700;
    color: var(--color-ink);
    font-size: 1.05rem;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .github-name:hover {
    color: var(--color-sakura-600);
  }

  .github-login {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  .github-bio {
    font-size: 0.825rem;
    color: var(--color-ink-muted);
    margin-top: 0.25rem;
    line-height: 1.4;
  }

  /* 贡献日历 */
  .github-chart-wrap {
    border-top: 1px solid var(--color-sakura-200);
    padding-top: 1rem;
  }

  .github-chart-title {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.625rem;
  }

  .github-chart-icon {
    color: var(--color-sakura-500);
    flex-shrink: 0;
  }

  .github-chart {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }

  /* Follow 按钮 */
  .github-follow-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: #24292f;
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    align-self: flex-start;
  }

  .github-follow-btn:hover {
    background: #1b1f23;
    transform: translateY(-1px);
  }
</style>
